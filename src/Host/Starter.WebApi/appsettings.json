// Configuration Guidance:
//   Development: Use User Secrets (dotnet user-secrets set "Section:Key" "value")
//   Environment Variables: Use double-underscore for nested keys (Serilog__MinimumLevel__Default=Warning)
//   Production: Use Azure Key Vault or environment variables -- never commit secrets
{
  "AllowedHosts": "*",

  "ExceptionHandling": {
    "IncludeStackTraceInDevelopment": true
  },

  "Database": {
    // Provider: Sqlite (default), SqlServer, or PostgreSql
    // Invalid values cause immediate startup failure
    "Provider": "Sqlite",
    // Auto-apply pending migrations on startup (disable in production if using CI/CD migrations)
    "AutoMigrate": true,
    // Command timeout in seconds (0 = provider default)
    "CommandTimeout": 30,
    // Log SQL parameters -- enable only in development
    "EnableSensitiveDataLogging": false,
    // Retry count for transient failures (SqlServer/PostgreSql only, ignored for Sqlite)
    "MaxRetryCount": 3
  },

  "ConnectionStrings": {
    "Sqlite": "Data Source=starter.db",
    "SqlServer": "Server=(localdb)\\mssqllocaldb;Database=StarterDb;Trusted_Connection=True;",
    "PostgreSql": "Host=localhost;Database=starterdb;Username=postgres;Password=postgres"
  },

  "Jwt": {
    // JWT signing key -- NEVER commit a real key here.
    // Development: dotnet user-secrets set "Jwt:SecretKey" "your-256-bit-secret-key-here-min-32-chars"
    // Production: Use environment variables or Azure Key Vault
    "SecretKey": "",
    "Issuer": "StarterWebApi",
    "Audience": "StarterWebApi",
    // Token lifetime in minutes (default: 60)
    "ExpirationMinutes": 60
  },

  "Authentication": {
    "Google": {
      // Google OAuth credentials -- optional, app works without.
      // When both ClientId and ClientSecret are empty, the Google auth handler is
      // not registered and the app starts normally without Google login support.
      // Development: dotnet user-secrets set "Authentication:Google:ClientId" "your-client-id"
      // Get credentials: Google Cloud Console -> APIs & Services -> Credentials
      "ClientId": "",
      "ClientSecret": ""
    }
  },

  "Cors": {
    // Production: list explicit allowed origins
    "AllowedOrigins": ["https://localhost:5101"],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["Content-Type", "Authorization"],
    "AllowCredentials": false
  },

  "OpenApi": {
    // Config-driven Scalar visibility (not environment check)
    // Set to false to disable interactive API documentation
    "EnableScalar": true,
    "Title": "Starter API",
    "Description": "A modular .NET 10 Web API starter"
  },

  "RateLimiting": {
    // Global rate limit applies to all endpoints by IP address
    "Enabled": true,
    "GlobalPermitLimit": 100,
    "GlobalWindowSeconds": 60,
    "FixedWindow": {
      "PermitLimit": 10,
      "WindowSeconds": 10,
      "QueueLimit": 0
    },
    "SlidingWindow": {
      "PermitLimit": 30,
      "WindowSeconds": 30,
      "SegmentsPerWindow": 3,
      "QueueLimit": 0
    },
    "TokenBucket": {
      "TokenLimit": 50,
      "ReplenishmentPeriodSeconds": 10,
      "TokensPerPeriod": 10,
      "QueueLimit": 0
    }
  },

  "Caching": {
    // Default expiration for cache-aside pattern entries
    "DefaultExpirationSeconds": 300,
    "SlidingExpirationSeconds": 60,
    // Set to a Redis connection string to switch from in-memory to Redis
    // e.g., "localhost:6379" or "my-redis.redis.cache.windows.net:6380,password=...,ssl=True"
    "RedisConnectionString": "",
    "RedisInstanceName": "starter:"
  },

  "Compression": {
    // Security: Keep false to prevent CRIME/BREACH side-channel attacks
    // Enable only if app is directly exposed to clients (not behind reverse proxy)
    "EnableForHttps": false,
    "BrotliLevel": "Fastest",
    "GzipLevel": "Fastest"
  },

  "HealthChecks": {
    // URI for the sample external dependency health check
    // Set to a real service URL in production (e.g., "https://api.example.com/health")
    "ExternalServiceUri": "",
    "TimeoutSeconds": 5
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithMachineName",
      {
        "Name": "WithCorrelationId",
        "Args": {
          "headerName": "X-Correlation-Id",
          "addValueIfHeaderAbsence": true
        }
      }
    ],
    "Properties": {
      "Application": "Starter.WebApi"
    },
    "Sinks": {
      "Console": {
        "Enabled": true,
        "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
      },
      "File": {
        "Enabled": false,
        // To enable file logging, set Enabled to true.
        // Logs are written to the Path with daily rolling files.
        "Path": "Logs/log-.txt",
        "RollingInterval": "Day",
        "RetainedFileCountLimit": 31,
        "FileSizeLimitBytes": 104857600
      },
      "Seq": {
        "Enabled": false,
        // To enable Seq, set Enabled to true and install Seq (https://datalust.co/seq).
        // Seq provides a structured log viewer for local development.
        "ServerUrl": "http://localhost:5341"
      },
      "OpenTelemetry": {
        "Enabled": false,
        // For generic OTLP collector: set Endpoint to your collector URL (e.g., http://localhost:4317)
        // For Azure Application Insights: set Endpoint to your ingestion URL
        //   (e.g., https://eastus-8.in.applicationinsights.azure.com/) and Protocol to "HttpProtobuf"
        "Endpoint": "http://localhost:4317",
        "Protocol": "Grpc"
      }
    },
    "RequestLogging": {
      "EnableClientIp": true,
      "EnableUserAgent": true,
      "EnableContentType": true
    }
  }
}
