{
  "Database": {
    "EnableSensitiveDataLogging": true
  },

  "Jwt": {
    "SecretKey": "DevOnlySecretKey-Replace-In-Production-Min32Chars!"
  },

  "Cors": {
    "AllowedOrigins": ["*"]
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Information"
      }
    }
  }
}
