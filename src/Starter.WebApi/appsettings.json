// Configuration Guidance:
//   Development: Use User Secrets (dotnet user-secrets set "Section:Key" "value")
//   Environment Variables: Use double-underscore for nested keys (ExceptionHandling__IncludeStackTraceInDevelopment=true)
//   Production: Use Azure Key Vault or environment variables -- never commit secrets
{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ExceptionHandling": {
    "IncludeStackTraceInDevelopment": true
  }
}
